        <mxCell id="wgTy8xsi1RIJN52i3a__-10" parent="wgTy8xsi1RIJN52i3a__-4" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;container=1;fontSize=15;" value="Como Residente (Personal Técnico), quiero registrar el avance físico de un rubro de mi proyecto asignado desde la app móvil, para reportar la ejecución diaria de la obra con información oportuna y trazable." vertex="1">
          <mxGeometry height="130" width="430" x="10" y="50" as="geometry" />
        </mxCell>
        <mxCell id="wgTy8xsi1RIJN52i3a__-11" parent="wgTy8xsi1RIJN52i3a__-4" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;container=1;" value="Estimacion tiempo : 16 horas" vertex="1">
          <mxGeometry height="30" width="160" x="10" y="180" as="geometry" />
        </mxCell>
        <mxCell id="wgTy8xsi1RIJN52i3a__-12" parent="wgTy8xsi1RIJN52i3a__-4" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;container=1;" value="Prioridad : Alta/Esencial&amp;nbsp;" vertex="1">
          <mxGeometry height="30" width="160" x="10" y="220" as="geometry" />
        </mxCell>
        <mxCell id="wgTy8xsi1RIJN52i3a__-13" parent="wgTy8xsi1RIJN52i3a__-4" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;container=1;" value="Dependiente: HU-17, HU-18" vertex="1">
          <mxGeometry height="30" width="160" x="290" y="220" as="geometry" />
        </mxCell>
        <mxCell id="wgTy8xsi1RIJN52i3a__-24" connectable="0" parent="1" style="group;verticalAlign=bottom;spacing=0;align=left;" value="" vertex="1">
          <mxGeometry height="280" width="460" x="150" y="380" as="geometry" />
        </mxCell>
        <mxCell id="wgTy8xsi1RIJN52i3a__-14" connectable="0" parent="wgTy8xsi1RIJN52i3a__-24" style="group;fillColor=#fff2cc;strokeColor=#d6b656;container=0;" value="" vertex="1">
