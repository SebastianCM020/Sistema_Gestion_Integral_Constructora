        <mxCell id="WNJdWxk-zVtyMWohtwfa-5" parent="WNJdWxk-zVtyMWohtwfa-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;container=1;" value="&lt;b&gt;&lt;span lang=&quot;EN-US&quot; style=&quot;font-size: 11pt; line-height: 115%; font-family: Arial, sans-serif;&quot;&gt;Controlar acceso por rango de fechas autorizado&lt;/span&gt;&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="350" x="70" as="geometry" />
        </mxCell>
        <mxCell id="WNJdWxk-zVtyMWohtwfa-6" parent="WNJdWxk-zVtyMWohtwfa-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;container=1;fontSize=15;" value="&lt;p data-start=&quot;5001&quot; data-end=&quot;5299&quot;&gt;Como Administrador del Sistema, quiero restringir el acceso de Residentes y Bodegueros al rango de fechas autorizado en cada asignación usuario-proyecto, para impedir operaciones fuera de la vigencia definida, proteger la información del proyecto y conservar trazabilidad de los intentos de acceso.&lt;/p&gt;&lt;br/&gt;&lt;p data-start=&quot;5301&quot; data-end=&quot;5548&quot;&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="130" width="430" x="10" y="50" as="geometry" />
        </mxCell>
        <mxCell id="WNJdWxk-zVtyMWohtwfa-7" parent="WNJdWxk-zVtyMWohtwfa-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;container=1;" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;Estimación tiempo :&amp;nbsp;&lt;/font&gt;&lt;span lang=&quot;EN-US&quot; style=&quot;font-size: 11pt; line-height: 115%; font-family: Arial, sans-serif;&quot;&gt;10 horas&lt;/span&gt;" vertex="1">
          <mxGeometry height="30" width="190" x="10" y="180" as="geometry" />
        </mxCell>
        <mxCell id="WNJdWxk-zVtyMWohtwfa-8" parent="WNJdWxk-zVtyMWohtwfa-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;container=1;" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;Prioridad : Alta/Escencial&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="170" x="10" y="220" as="geometry" />
        </mxCell>
        <mxCell id="WNJdWxk-zVtyMWohtwfa-9" parent="WNJdWxk-zVtyMWohtwfa-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;container=1;" value="&lt;font style=&quot;font-size: 13px;&quot;&gt;Dependiente : HU-01, HU-08, HU-09, HU-10, HU-15, HU-16, HU-17, HU-19, HU-21, HU-22, HU-24, HU-25&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="240" x="220" y="220" as="geometry" />
        </mxCell>
        <mxCell id="WNJdWxk-zVtyMWohtwfa-10" connectable="0" parent="1" style="group" value="" vertex="1">
