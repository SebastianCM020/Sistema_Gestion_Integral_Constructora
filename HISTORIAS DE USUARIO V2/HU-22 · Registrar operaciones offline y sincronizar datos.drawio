        <mxCell id="bdwxCEJItwgNG5l-_DqY-19" parent="bdwxCEJItwgNG5l-_DqY-14" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;container=1;fontSize=15;" value="&lt;p data-start=&quot;5001&quot; data-end=&quot;5299&quot; style=&quot;text-align: justify;&quot;&gt;&lt;span data-start=&quot;7548&quot; data-end=&quot;7556&quot; style=&quot;&quot;&gt;Como&lt;/span&gt; Residente,&amp;nbsp;&lt;span data-start=&quot;7570&quot; data-end=&quot;7580&quot; style=&quot;&quot;&gt;quiero&lt;/span&gt; registrar avances, consumos y evidencias fotográficas aun cuando no tenga conexión a Internet,&amp;nbsp;&lt;span data-start=&quot;7678&quot; data-end=&quot;7686&quot; style=&quot;&quot;&gt;para&lt;/span&gt; continuar trabajando en campo y sincronizar la información automáticamente cuando se restablezca la conectividad.&lt;/p&gt;&lt;p data-start=&quot;5301&quot; data-end=&quot;5548&quot;&gt;&lt;/p&gt;" vertex="1">
