# ─────────────────────────────────────────────────────────────────────────────
# .gitattributes
# Fuerza LF en scripts shell para evitar errores CRLF en Docker/Linux.
# ─────────────────────────────────────────────────────────────────────────────
*.sh        text eol=lf
*.bash      text eol=lf
Dockerfile  text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.prisma    text eol=lf
*.sql       text eol=lf
*.env       text eol=lf
