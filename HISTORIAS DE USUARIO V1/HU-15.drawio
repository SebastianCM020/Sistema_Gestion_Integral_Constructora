        <mxCell id="xi1pMGoUl8Vyy48r--zN-6" parent="xi1pMGoUl8Vyy48r--zN-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;container=1;fontSize=15;" value="Como Administrador del Sistema, quiero crear nuevos proyectos dentro de la plataforma, para habilitar instancias independientes de operación y control para cada obra." vertex="1">
