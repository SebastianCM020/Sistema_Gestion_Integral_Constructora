        </mxCell>
        <mxCell id="NW7HwyyEYMYk5egLmpf2-6" parent="NW7HwyyEYMYk5egLmpf2-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;container=1;fontSize=15;" value="&lt;span lang=&quot;EN-US&quot; style=&quot;font-size: 11pt; line-height: 115%; font-family: Arial, sans-serif;&quot;&gt;Como Auxiliar de Contabilidad o Residente, quiero crear requerimientos de compra con materiales, cantidades y justificación, para solicitar oportunamente los insumos necesarios del proyecto.&lt;/span&gt;" vertex="1">
