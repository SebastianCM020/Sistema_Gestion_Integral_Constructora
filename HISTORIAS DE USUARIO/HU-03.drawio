        <mxCell id="Q3rIHbWVIbV8S54wCumc-6" parent="Q3rIHbWVIbV8S54wCumc-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;container=1;fontSize=15;" value="Como Residente , quiero capturar y asociar evidencia fotográfica a cada avance físico registrado, para respaldar técnicamente la ejecución del rubro reportado." vertex="1">
          <mxGeometry height="130" width="430" x="10" y="50" as="geometry" />
