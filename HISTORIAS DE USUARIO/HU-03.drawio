        <mxCell id="Q3rIHbWVIbV8S54wCumc-9" parent="Q3rIHbWVIbV8S54wCumc-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;container=1;" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;Dependiente : HU-01&lt;/font&gt;" vertex="1">
