        <mxCell id="eSVirTn4XRbCqDk6yfx3-6" parent="eSVirTn4XRbCqDk6yfx3-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;container=1;fontSize=15;" value="Como Contador o Presidente, quiero consultar la planilla mensual de un proyecto antes de exportarla, para revisar el consolidado del periodo y validar su contenido de cobro." vertex="1">
