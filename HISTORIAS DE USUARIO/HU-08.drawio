        <mxCell id="xJLVZSSzEe3v9c47FOGg-6" parent="xJLVZSSzEe3v9c47FOGg-1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;container=1;fontSize=15;" value="Como Bodeguero, quiero registrar la recepción física de materiales asociados a un requerimiento aprobado, para mantener actualizado el ingreso real de insumos del proyecto." vertex="1">
