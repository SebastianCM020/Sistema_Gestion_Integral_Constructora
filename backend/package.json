{
  "name": "icaro-backend",
  "version": "1.0.0",
  "description": "API REST — Sistema de Gestión Integral ICARO CONSTRUCTORES BMGM S.A.S.",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "jest --testPathPatterns=tests/ --forceExit --detectOpenHandles",
    "test:security": "jest --testPathPatterns=tests/security --forceExit",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:generate": "npx prisma generate",
    "prisma:studio": "npx prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.78.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "pdfkit": "^0.19.1",
    "pg": "^8.11.5",
    "socket.io": "^4.8.3",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "babel-jest": "^30.4.1",
    "jest": "^30.3.0",
    "nodemon": "^3.1.0",
    "prisma": "^5.13.0",
    "supertest": "^7.2.2"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 15000,
    "verbose": true,
    "transformIgnorePatterns": [
      "node_modules/(?!(uuid)/)"
    ],
    "transform": {
      "^.+\\.js$": "babel-jest"
    }
  }
}
