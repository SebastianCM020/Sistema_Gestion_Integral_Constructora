// ─────────────────────────────────────────────────────────────────────────────
// schema.prisma — Sistema ICARO CONSTRUCTORES BMGM S.A.S.
// Basado en: diagramas_arquitectura.md (Sección 2.1 — Diagrama ER completo)
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── SEGURIDAD Y ACCESO ────────────────────────────────────────────────

model Rol {
  id          Int       @id @default(autoincrement())
  nombre      String    @unique @db.VarChar(50)
  descripcion String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  usuarios    Usuario[]

  @@map("roles")
}

model Usuario {
  id           String    @id @default(uuid()) @db.Uuid
  nombre       String    @db.VarChar(100)
  apellido     String    @db.VarChar(100)
  email        String    @unique @db.VarChar(150)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  idRol        Int       @map("id_rol")
  activo       Boolean   @default(true)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  rol                    Rol                       @relation(fields: [idRol], references: [id])
  asignaciones           AsignacionProyectoUsuario[]
  avancesRegistrados     AvanceObra[]              @relation("ResidenteAvance")
  avancesValidados       AvanceObra[]              @relation("SuperintendenteAvance")
  requerimientosSolicitados RequerimientoCompra[]  @relation("SolicitanteReq")
  requerimientosAprobados   RequerimientoCompra[]  @relation("AprobadorReq")
  cierresMensuales       CierreMensual[]
  planillasGeneradas     PlanillaPdf[]
  auditLogs              AuditLog[]
  movimientosRegistrados MovimientoInventario[]    @relation("MovimientosBodeguero") // HU-03
  proyectosResponsable   Proyecto[]                @relation("ProyectoResponsable")
  // Sprint 7
  ordenesCambioSolicitadas OrdenCambio[]          @relation("OrdenCambioSolicitante")
  ordenesCambioAprobadas   OrdenCambio[]          @relation("OrdenCambioAprobador")
  notificaciones              NotificacionSistema[]
  consolidacionesGeneradas    ConsolidacionMensual[]  @relation("ConsolidacionGenerador") // Sprint 10
  validacionesEjecutadas      ValidacionPreCierre[]   @relation("ValidacionEjecutor")     // Sprint 10

  @@map("usuarios")
}

// ─── PROYECTOS ─────────────────────────────────────────────────────────

model Proyecto {
  id                 String    @id @default(uuid()) @db.Uuid
  codigo             String    @unique @db.VarChar(30)
  nombre             String    @db.VarChar(200)
  descripcion        String?   @db.Text
  entidadContratante String?   @map("entidad_contratante") @db.VarChar(200)
  numeroContrato     String?   @map("numero_contrato") @db.VarChar(50)
  presupuestoTotal   Decimal   @map("presupuesto_total") @db.Decimal(14, 2)
  fechaInicio        DateTime  @map("fecha_inicio") @db.Date
  fechaFinPrevista   DateTime  @map("fecha_fin_prevista") @db.Date
  estado             String    @default("ACTIVO") @db.VarChar(20)
  idResponsable      String?   @map("id_responsable") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz

  responsable        Usuario?  @relation("ProyectoResponsable", fields: [idResponsable], references: [id])
  asignaciones       AsignacionProyectoUsuario[]
  rubros             Rubro[]
  avances            AvanceObra[]
  requerimientos     RequerimientoCompra[]
  inventarios        InventarioProyecto[]
  cierres            CierreMensual[]
  movimientos        MovimientoInventario[]     // HU-03
  ordenesCambio      OrdenCambio[]              // Sprint 7
  consolidaciones    ConsolidacionMensual[]              // Sprint 10
  validaciones       ValidacionPreCierre[]               // Sprint 10

  @@map("proyectos")
}

model AsignacionProyectoUsuario {
  id            String    @id @default(uuid()) @db.Uuid
  idUsuario     String    @map("id_usuario") @db.Uuid
  idProyecto    String    @map("id_proyecto") @db.Uuid
  fechaInicio   DateTime  @map("fecha_inicio") @db.Date
  fechaFin      DateTime  @map("fecha_fin") @db.Date
  accessMode    String    @default("READ_WRITE") @map("access_mode") @db.VarChar(20)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz

  usuario        Usuario  @relation(fields: [idUsuario], references: [id])
  proyecto       Proyecto @relation(fields: [idProyecto], references: [id])

  @@map("asignacion_proyecto_usuario")
}

// ─── MÓDULO TÉCNICO — OBRA ─────────────────────────────────────────────

model Rubro {
  id                  String    @id @default(uuid()) @db.Uuid
  idProyecto          String    @map("id_proyecto") @db.Uuid
  codigo              String    @db.VarChar(30)
  descripcion         String    @db.Text
  unidad              String    @db.VarChar(20)
  precioUnitario      Decimal   @map("precio_unitario") @db.Decimal(12, 4)
  cantidadPresupuestada Decimal @map("cantidad_presupuestada") @db.Decimal(12, 4)
  cantidadEjecutada   Decimal   @default(0) @map("cantidad_ejecutada") @db.Decimal(12, 4)
  activo              Boolean   @default(true)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz

  proyecto   Proyecto    @relation(fields: [idProyecto], references: [id])
  avances    AvanceObra[]
  ordenesCambio OrdenCambio[]  // Sprint 7

  @@map("rubros")
}

model AvanceObra {
  id                String    @id @default(uuid()) @db.Uuid
  idProyecto        String    @map("id_proyecto") @db.Uuid
  idRubro           String    @map("id_rubro") @db.Uuid
  idResidente       String    @map("id_residente") @db.Uuid
  idSuperintendente String?   @map("id_superintendente") @db.Uuid
  cantidadAvance    Decimal   @map("cantidad_avance") @db.Decimal(12, 4)
  fechaRegistro     DateTime  @map("fecha_registro") @db.Date
  // Estados: PENDING_SYNC | SYNCED | VALIDATED | REJECTED
  estado            String    @default("PENDING_SYNC") @db.VarChar(20)
  syncTimestamp     DateTime? @map("sync_timestamp") @db.Timestamptz
  notas             String?   @db.Text
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz

  proyecto          Proyecto  @relation(fields: [idProyecto], references: [id])
  rubro             Rubro     @relation(fields: [idRubro], references: [id])
  residente         Usuario   @relation("ResidenteAvance", fields: [idResidente], references: [id])
  superintendente   Usuario?  @relation("SuperintendenteAvance", fields: [idSuperintendente], references: [id])
  evidencias        EvidenciaFotografica[]

  @@map("avance_obra")
}

model EvidenciaFotografica {
  id               String    @id @default(uuid()) @db.Uuid
  idAvance         String    @map("id_avance") @db.Uuid
  urlImagen        String    @map("url_imagen") @db.VarChar(500)
  storageKey       String    @map("storage_key") @db.VarChar(300)
  sizeBytes        Int?      @map("size_bytes")
  mimeType         String?   @map("mime_type") @db.VarChar(50)
  timestampCaptura DateTime? @map("timestamp_captura") @db.Timestamptz
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz

  avance  AvanceObra @relation(fields: [idAvance], references: [id], onDelete: Cascade)

  @@map("evidencia_fotografica")
}

// ─── MÓDULO ADMINISTRATIVO — COMPRAS E INVENTARIO ──────────────────────

model Material {
  id          String    @id @default(uuid()) @db.Uuid
  codigo      String    @unique @db.VarChar(30)
  nombre      String    @db.VarChar(200)
  categoria   String    @db.VarChar(80)              // HU-02: búsqueda/filtro por categoría
  unidad      String    @db.VarChar(20)              // ej. "kg", "m3", "unidad"
  descripcion String?   @db.Text
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  detallesRequerimiento DetalleRequerimiento[]
  inventarios           InventarioProyecto[]
  movimientos           MovimientoInventario[]

  @@map("materiales")
}

model RequerimientoCompra {
  id                  String    @id @default(uuid()) @db.Uuid
  idProyecto          String    @map("id_proyecto") @db.Uuid
  idSolicitante       String    @map("id_solicitante") @db.Uuid
  idAprobador         String?   @map("id_aprobador") @db.Uuid
  // Estados: EN_REVISION | APROBADO | RECHAZADO | RECIBIDO
  estado              String    @default("EN_REVISION") @db.VarChar(20)
  justificacion       String?   @db.Text
  comentarioRechazo   String?   @map("comentario_rechazo") @db.Text
  fechaSolicitud      DateTime  @default(now()) @map("fecha_solicitud") @db.Timestamptz
  fechaAprobacion     DateTime? @map("fecha_aprobacion") @db.Timestamptz
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  proyecto    Proyecto  @relation(fields: [idProyecto], references: [id])
  solicitante Usuario   @relation("SolicitanteReq", fields: [idSolicitante], references: [id])
  aprobador   Usuario?  @relation("AprobadorReq", fields: [idAprobador], references: [id])
  detalles    DetalleRequerimiento[]

  @@map("requerimiento_compra")
}

model DetalleRequerimiento {
  id                 String   @id @default(uuid()) @db.Uuid
  idRequerimiento    String   @map("id_requerimiento") @db.Uuid
  idMaterial         String   @map("id_material") @db.Uuid
  cantidadSolicitada Decimal  @map("cantidad_solicitada") @db.Decimal(12, 4)
  cantidadRecibida   Decimal  @default(0) @map("cantidad_recibida") @db.Decimal(12, 4)

  requerimiento RequerimientoCompra @relation(fields: [idRequerimiento], references: [id], onDelete: Cascade)
  material      Material            @relation(fields: [idMaterial], references: [id])

  @@map("detalle_requerimiento")
}

model InventarioProyecto {
  idMaterial           String   @map("id_material") @db.Uuid
  idProyecto           String   @map("id_proyecto") @db.Uuid
  cantidadDisponible   Decimal  @default(0) @map("cantidad_disponible") @db.Decimal(12, 4)
  ultimaActualizacion  DateTime @default(now()) @updatedAt @map("ultima_actualizacion") @db.Timestamptz

  material  Material  @relation(fields: [idMaterial], references: [id])
  proyecto  Proyecto  @relation(fields: [idProyecto], references: [id])

  @@id([idMaterial, idProyecto])
  @@map("inventario_proyecto")
}

// ─── HU-03: Movimientos de inventario (libro de entradas/salidas) ──────────

model MovimientoInventario {
  id                  String    @id @default(uuid()) @db.Uuid
  idMaterial          String    @map("id_material") @db.Uuid
  idProyecto          String    @map("id_proyecto") @db.Uuid
  idUsuario           String    @map("id_usuario") @db.Uuid           // Bodeguero/Residente que registra
  // Tipos: ENTRADA | SALIDA | AJUSTE
  tipoMovimiento      String    @map("tipo_movimiento") @db.VarChar(20)
  cantidad            Decimal   @db.Decimal(12, 4)
  cantidadAnterior    Decimal   @default(0) @map("cantidad_anterior") @db.Decimal(12, 4)
  cantidadResultante  Decimal   @default(0) @map("cantidad_resultante") @db.Decimal(12, 4)
  observacion         String?   @db.Text
  fechaMovimiento     DateTime  @default(now()) @map("fecha_movimiento") @db.Timestamptz
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz

  material  Material  @relation(fields: [idMaterial], references: [id])
  proyecto  Proyecto  @relation(fields: [idProyecto], references: [id])
  usuario   Usuario   @relation("MovimientosBodeguero", fields: [idUsuario], references: [id])

  @@map("movimiento_inventario")
}

// ─── MÓDULO CONTABLE Y REPORTES ────────────────────────────────────────

model CierreMensual {
  id           String    @id @default(uuid()) @db.Uuid
  idProyecto   String    @map("id_proyecto") @db.Uuid
  idContador   String    @map("id_contador") @db.Uuid
  mesAnio      String    @map("mes_anio") @db.VarChar(7) // "YYYY-MM"
  // Estados: ABIERTO | CERRADO
  estadoCierre String    @default("ABIERTO") @map("estado_cierre") @db.VarChar(10)
  montoTotal   Decimal   @default(0) @map("monto_total") @db.Decimal(14, 2)
  hashSeguridad String?  @map("hash_seguridad") @db.VarChar(64)
  fechaCierre  DateTime? @map("fecha_cierre") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  proyecto  Proyecto      @relation(fields: [idProyecto], references: [id])
  contador  Usuario       @relation(fields: [idContador], references: [id])
  planillas       PlanillaPdf[]
  consolidacion   ConsolidacionMensual?  // Sprint 10

  @@map("cierre_mensual")
}

model PlanillaPdf {
  id           String    @id @default(uuid()) @db.Uuid
  idCierre     String    @map("id_cierre") @db.Uuid
  idGenerador  String    @map("id_generador") @db.Uuid
  urlArchivo   String?   @map("url_archivo") @db.VarChar(500)
  storageKey   String?   @map("storage_key") @db.VarChar(300)
  // Estados: PENDING | GENERATING | READY | ERROR
  estadoGen    String    @default("PENDING") @map("estado_gen") @db.VarChar(15)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  cierre     CierreMensual @relation(fields: [idCierre], references: [id])
  generador  Usuario       @relation(fields: [idGenerador], references: [id])

  @@map("planilla_pdf")
}

// ─── AUDITORÍA INMUTABLE ───────────────────────────────────────────────

model AuditLog {
  id          BigInt    @id @default(autoincrement())
  tabla       String    @db.VarChar(60)
  operacion   String    @db.VarChar(10) // INSERT | UPDATE | DELETE
  idRegistro  String?   @map("id_registro") @db.Uuid
  idUsuario   String?   @map("id_usuario") @db.Uuid
  datosAntes  Json?     @map("datos_antes")
  datosDespues Json?    @map("datos_despues")
  ipOrigen    String?   @map("ip_origen") @db.VarChar(45)
  timestamp   DateTime  @default(now()) @db.Timestamptz

  usuario  Usuario? @relation(fields: [idUsuario], references: [id], onDelete: SetNull)

  @@map("audit_log")
}

// ── SPRINT 7: ÓRDENES DE CAMBIO ──

model OrdenCambio {
  id                   String    @id @default(uuid()) @db.Uuid
  idProyecto           String    @map("id_proyecto") @db.Uuid
  idRubro              String    @map("id_rubro") @db.Uuid
  idSolicitante        String    @map("id_solicitante") @db.Uuid
  idAprobador          String?   @map("id_aprobador") @db.Uuid
  // Estados: PENDIENTE | APROBADA | RECHAZADA
  estado               String    @default("PENDIENTE") @db.VarChar(20)
  motivo               String    @db.Text
  cantidadAdicional    Decimal   @map("cantidad_adicional") @db.Decimal(12, 4)
  comentarioAprobador  String?   @map("comentario_aprobador") @db.Text
  fechaSolicitud       DateTime  @default(now()) @map("fecha_solicitud") @db.Timestamptz
  fechaResolucion      DateTime? @map("fecha_resolucion") @db.Timestamptz
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz

  proyecto    Proyecto  @relation(fields: [idProyecto], references: [id])
  rubro       Rubro     @relation(fields: [idRubro], references: [id])
  solicitante Usuario   @relation("OrdenCambioSolicitante", fields: [idSolicitante], references: [id])
  aprobador   Usuario?  @relation("OrdenCambioAprobador", fields: [idAprobador], references: [id])

  @@map("ordenes_cambio")
}

// ── SPRINT 7: NOTIFICACIONES INTERNAS ──

model NotificacionSistema {
  id               String    @id @default(uuid()) @db.Uuid
  idUsuarioDest    String    @map("id_usuario_dest") @db.Uuid
  tipo             String    @db.VarChar(40)   // REQUERIMIENTO_CREADO | APROBADO | RECHAZADO | ORDEN_CAMBIO
  titulo           String    @db.VarChar(200)
  mensaje          String    @db.Text
  idReferencia     String?   @map("id_referencia") @db.Uuid
  tablaReferencia  String?   @map("tabla_referencia") @db.VarChar(60)
  leida            Boolean   @default(false)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz

  usuarioDest  Usuario @relation(fields: [idUsuarioDest], references: [id], onDelete: Cascade)

  @@map("notificaciones_sistema")
}

// ═══════════════════════════════════════════════════════════════════════════════
// SPRINT 10 — Auditoría, Consolidación y Cierre Mensual
// ═══════════════════════════════════════════════════════════════════════════════

// Snapshot contable-operativo generado en el momento del cierre.
// Relación 1:1 con CierreMensual.
model ConsolidacionMensual {
  id                   String   @id @default(uuid()) @db.Uuid
  idCierre             String   @unique @map("id_cierre") @db.Uuid
  idProyecto           String   @map("id_proyecto") @db.Uuid
  mesAnio              String   @map("mes_anio") @db.VarChar(7)

  // Avances
  totalAvanceQty       Decimal  @default(0) @map("total_avance_qty") @db.Decimal(14, 4)
  totalAvanceMonto     Decimal  @default(0) @map("total_avance_monto") @db.Decimal(14, 2)
  rubrosEjecutados     Int      @default(0) @map("rubros_ejecutados")

  // Compras
  totalRequerimientos  Int      @default(0) @map("total_requerimientos")
  totalComprasMonto    Decimal  @default(0) @map("total_compras_monto") @db.Decimal(14, 2)
  totalRecepciones     Int      @default(0) @map("total_recepciones")

  // Consumos en obra
  totalConsumosQty     Decimal  @default(0) @map("total_consumos_qty") @db.Decimal(14, 4)
  totalConsumosMonto   Decimal  @default(0) @map("total_consumos_monto") @db.Decimal(14, 2)

  // Snapshot inventario (JSON)
  snapshotInventario   Json?    @map("snapshot_inventario")

  // Avance global del proyecto en %
  porcentajeAvance     Decimal  @default(0) @map("porcentaje_avance") @db.Decimal(5, 2)

  // Metadata
  generadoPor          String   @map("generado_por") @db.Uuid
  generadoEn           DateTime @default(now()) @map("generado_en") @db.Timestamptz
  hashPayload          String?  @map("hash_payload") @db.VarChar(64)

  cierre   CierreMensual @relation(fields: [idCierre], references: [id])
  proyecto Proyecto      @relation(fields: [idProyecto], references: [id])
  usuario  Usuario       @relation("ConsolidacionGenerador", fields: [generadoPor], references: [id])

  @@map("consolidacion_mensual")
}

// Registro de cada intento de validación pre-cierre (auditable e inmutable).
model ValidacionPreCierre {
  id            String   @id @default(uuid()) @db.Uuid
  idProyecto    String   @map("id_proyecto") @db.Uuid
  mesAnio       String   @map("mes_anio") @db.VarChar(7)
  // 'OK' | 'BLOQUEADO' | 'PENDIENTE'
  estado        String   @default("PENDIENTE") @db.VarChar(10)
  errores       Json?
  ejecutadoPor  String   @map("ejecutado_por") @db.Uuid
  ejecutadoEn   DateTime @default(now()) @map("ejecutado_en") @db.Timestamptz

  proyecto  Proyecto @relation(fields: [idProyecto], references: [id])
  ejecutor  Usuario  @relation("ValidacionEjecutor", fields: [ejecutadoPor], references: [id])

  @@map("validacion_pre_cierre")
}
